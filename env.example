# Optional. Absolute path to env file (default: `.env` in current working directory).
# DOTENV_PATH=

# Optional. GitHub personal access token for higher REST API rate limits when polling.
# https://docs.github.com/en/authentication/keeping-your-account-and-data-secure/managing-your-personal-access-tokens
GITHUB_TOKEN=

# If SMTP_HOST is unset or empty, new listings are only printed to stdout (no email).
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_TO=
SMTP_USER=
SMTP_PASSWORD=

# Prefix for the email subject line (default if unset: "Internship notifier").
SMTP_SUBJECT_PREFIX=Internship notifier
