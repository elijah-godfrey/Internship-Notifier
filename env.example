# Optional. Absolute path to env file (default: .env in current working directory).
# DOTENV_PATH=

# Optional. Path to notifier.toml when it is not ./notifier.toml in cwd.
# NOTIFIER_CONFIG=

# Optional. GitHub token for higher API rate limits.
GITHUB_TOKEN=

# Required only when prestige filtering encounters an uncached company.
OPENAI_API_KEY=sk-yourOpenAIKeyHere

# Optional. Defaults to the inexpensive model used by the prestige ranker.
OPENAI_PRESTIGE_MODEL=gpt-5.6-terra

# If SMTP_HOST is empty, notifier only prints new listings (no email).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=yourgmail@gmail.com
SMTP_TO=youremail@gmail.com
SMTP_USER=yourgmail@gmail.com

# Gmail: use a 16-character App Password (not your normal Gmail password).
# Google displays spaces for readability; store without spaces.
# Example 16 chars: abcdwxyz1234pqrs
SMTP_PASSWORD=abcdwxyz1234pqrs

# Optional email subject prefix.
SMTP_SUBJECT_PREFIX=Internship notifier
